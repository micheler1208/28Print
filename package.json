{
  "name": "fede-kart",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "setup": "tsx --tsconfig tsconfig.json scripts/setup-local.ts",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx --tsconfig tsconfig.json prisma/seed.ts",
    "db:seed:local": "tsx --tsconfig tsconfig.json prisma/seed.ts",
    "db:bootstrap:prod": "tsx --tsconfig tsconfig.json scripts/bootstrap-production.ts",
    "vercel-build": "prisma migrate deploy && tsx --tsconfig tsconfig.json scripts/bootstrap-production.ts && next build",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx --tsconfig tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.1",
    "@vercel/blob": "^2.3.1",
    "next": "14.2.25",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "22.13.4",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "prisma": "6.19.1",
    "tsx": "4.19.2",
    "typescript": "5.8.2",
    "vitest": "3.0.8"
  }
}
